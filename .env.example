# ============================================================
# ENVIRONMENT VARIABLES — copy to ".env" for local dev
# Never commit the real ".env" file (already in .gitignore)
#
# For production (Render): set these in the Render dashboard
# under Environment → Add Environment Variable.
# ============================================================

# ── Active Spring Profile ───────────────────────────────────
# dev  → uses application-dev.properties  (MySQL, show-sql, H2 console)
# prod → uses application-prod.properties (Postgres, silent, no H2 console)
# test → uses application-test.properties (H2 in-memory, used by mvn test)
SPRING_PROFILES_ACTIVE=dev

# ── Database ─────────────────────────────────────────────────
# LOCAL DEV (dev profile):
DB_URL=jdbc:mysql://localhost:3306/walletdb
DB_USERNAME=root
DB_PASSWORD=your_local_mysql_password

# PRODUCTION (prod profile on Render) — replace with your Neon/Supabase URL:
# DB_URL=jdbc:postgresql://ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
# DB_USERNAME=neondb_owner
# DB_PASSWORD=your_neon_password

# ── JWT ──────────────────────────────────────────────────────
# PRODUCTION: generate a strong secret (min 32 chars) and set this.
# Example (generate with): openssl rand -base64 64
# JWT_SECRET=your-very-long-random-production-secret-at-least-32-characters
# For local dev the default in application.properties is used (not secure).

# ── JWT Expiry (optional — defaults to 1 hour) ───────────────
# JWT_EXPIRATION_MS=3600000

# ── Demo Account Passwords ───────────────────────────────────
# DEMO_ADMIN_PASSWORD=admin123
# DEMO_USER_PASSWORD=user123

# ── Server Port ──────────────────────────────────────────────
# Local dev: 8080 (default)
# Production (Render): Render sets PORT automatically — do not override it.
# SERVER_PORT=8080